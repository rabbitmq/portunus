{minimum_otp_vsn, "27"}.
{deps, [
        {ra, "3.1.8"},
        {seshat, "1.0.1"}
]}.
{project_plugins, [rebar3_hex, rebar3_ex_doc]}.
{profiles,
 [{test, [{deps, [proper, meck]}]}]
}.
{dist_node, [
    {sname, 'portunus'}
]}.
{erl_opts, [debug_info,
            warn_export_vars,
            warn_shadow_vars,
            warn_obsolete_guard]}.
{dialyzer, [{warnings,
             [error_handling,
              unmatched_returns]},
            {plt_extra_apps, [eunit, ra, seshat]}]}.
{xref_extra_paths, ["test"]}.
{xref_checks, [undefined_function_calls,
               undefined_functions,
               locals_not_used,
               deprecated_function_calls,
               deprecated_functions]}.
{hex, [
  {doc, #{provider => ex_doc}}
]}.
{ex_doc, [
  {main, "README.md"},
  {extras, ["README.md", "LICENSE"]},
  {source_url, "https://github.com/rabbitmq/portunus"}
]}.
